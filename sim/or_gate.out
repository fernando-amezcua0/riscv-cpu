:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2009.vpi";
S_0x63fb6a6655a0 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x63fb6a665730 .scope module, "tb_or_gate" "tb_or_gate" 3 3;
 .timescale -9 -12;
v0x63fb6a6b2d90_0 .var "a", 0 0;
v0x63fb6a6b2e60_0 .var "b", 0 0;
v0x63fb6a6b2f30_0 .net "y", 0 0, L_0x63fb6a6b3030;  1 drivers
S_0x63fb6a6a1240 .scope module, "dut" "or_gate" 3 7, 4 1 0, S_0x63fb6a665730;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /OUTPUT 1 "y";
L_0x63fb6a6b3030 .functor OR 1, v0x63fb6a6b2d90_0, v0x63fb6a6b2e60_0, C4<0>, C4<0>;
v0x63fb6a6a1470_0 .net "a", 0 0, v0x63fb6a6b2d90_0;  1 drivers
v0x63fb6a6b2bb0_0 .net "b", 0 0, v0x63fb6a6b2e60_0;  1 drivers
v0x63fb6a6b2c70_0 .net "y", 0 0, L_0x63fb6a6b3030;  alias, 1 drivers
    .scope S_0x63fb6a665730;
T_0 ;
    %vpi_call/w 3 14 "$dumpfile", "sim/or_gate.vcd" {0 0 0};
    %vpi_call/w 3 15 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x63fb6a665730 {0 0 0};
    %end;
    .thread T_0;
    .scope S_0x63fb6a665730;
T_1 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x63fb6a6b2d90_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x63fb6a6b2e60_0, 0, 1;
    %delay 10000, 0;
    %vpi_call/w 3 20 "$display", "a=%b b=%b y=%b | expect 0", v0x63fb6a6b2d90_0, v0x63fb6a6b2e60_0, v0x63fb6a6b2f30_0 {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x63fb6a6b2d90_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x63fb6a6b2e60_0, 0, 1;
    %delay 10000, 0;
    %vpi_call/w 3 23 "$display", "a=%b b=%b y=%b | expect 1", v0x63fb6a6b2d90_0, v0x63fb6a6b2e60_0, v0x63fb6a6b2f30_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x63fb6a6b2d90_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x63fb6a6b2e60_0, 0, 1;
    %delay 10000, 0;
    %vpi_call/w 3 26 "$display", "a=%b b=%b y=%b | expect 1", v0x63fb6a6b2d90_0, v0x63fb6a6b2e60_0, v0x63fb6a6b2f30_0 {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x63fb6a6b2d90_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x63fb6a6b2e60_0, 0, 1;
    %delay 10000, 0;
    %vpi_call/w 3 29 "$display", "a=%b b=%b y=%b | expect 1", v0x63fb6a6b2d90_0, v0x63fb6a6b2e60_0, v0x63fb6a6b2f30_0 {0 0 0};
    %vpi_call/w 3 31 "$finish" {0 0 0};
    %end;
    .thread T_1;
