#! /usr/bin/vvp
:ivl_version "12.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 12;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2009.vpi";
S_0x5c77ccbba5a0 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x5c77ccbba730 .scope module, "tb_and_gate" "tb_and_gate" 3 3;
 .timescale -9 -12;
v0x5c77ccc07fd0_0 .var "a", 0 0;
v0x5c77ccc080a0_0 .var "b", 0 0;
v0x5c77ccc08170_0 .net "y", 0 0, L_0x5c77ccc08270;  1 drivers
S_0x5c77ccbf6240 .scope module, "dut" "and_gate" 3 7, 4 1 0, S_0x5c77ccbba730;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /OUTPUT 1 "y";
L_0x5c77ccc08270 .functor AND 1, v0x5c77ccc07fd0_0, v0x5c77ccc080a0_0, C4<1>, C4<1>;
v0x5c77ccbf6470_0 .net "a", 0 0, v0x5c77ccc07fd0_0;  1 drivers
v0x5c77ccc07df0_0 .net "b", 0 0, v0x5c77ccc080a0_0;  1 drivers
v0x5c77ccc07eb0_0 .net "y", 0 0, L_0x5c77ccc08270;  alias, 1 drivers
    .scope S_0x5c77ccbba730;
T_0 ;
    %vpi_call/w 3 14 "$dumpfile", "sim/and_gate.vcd" {0 0 0};
    %vpi_call/w 3 15 "$dumpvars", 32'sb00000000000000000000000000000000, S_0x5c77ccbba730 {0 0 0};
    %end;
    .thread T_0;
    .scope S_0x5c77ccbba730;
T_1 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c77ccc07fd0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c77ccc080a0_0, 0, 1;
    %delay 10000, 0;
    %vpi_call/w 3 20 "$display", "a=%b b=%b y=%b | expect 0", v0x5c77ccc07fd0_0, v0x5c77ccc080a0_0, v0x5c77ccc08170_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c77ccc07fd0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c77ccc080a0_0, 0, 1;
    %delay 10000, 0;
    %vpi_call/w 3 23 "$display", "a=%b b=%b y=%b | expect 0", v0x5c77ccc07fd0_0, v0x5c77ccc080a0_0, v0x5c77ccc08170_0 {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c77ccc07fd0_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c77ccc080a0_0, 0, 1;
    %delay 10000, 0;
    %vpi_call/w 3 26 "$display", "a=%b b=%b y=%b | expect 0", v0x5c77ccc07fd0_0, v0x5c77ccc080a0_0, v0x5c77ccc08170_0 {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c77ccc07fd0_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c77ccc080a0_0, 0, 1;
    %delay 10000, 0;
    %vpi_call/w 3 29 "$display", "a=%b b=%b y=%b | expect 1", v0x5c77ccc07fd0_0, v0x5c77ccc080a0_0, v0x5c77ccc08170_0 {0 0 0};
    %vpi_call/w 3 31 "$finish" {0 0 0};
    %end;
    .thread T_1;
# The file index is used to find the file name in the following table.
:file_names 5;
    "N/A";
    "<interactive>";
    "-";
    "tb/tb_and_gate.sv";
    "rtl/and_gate.sv";
